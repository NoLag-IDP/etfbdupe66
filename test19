-- Try CoreGui first, fallback to PlayerGui if blocked
local function getGuiParent()
    local success, result = pcall(function()
        return game:GetService("CoreGui")
    end)
    if success then
        return result
    else
        return player:WaitForChild("PlayerGui")
    end
end

