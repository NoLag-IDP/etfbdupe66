-- ===================== DUPE LOGIC (PROPERLY FIXED) =====================
local function duplicateItem()
    local char = player.Character
    if not char then 
        warn("⚠️ Character not found")
        return 
    end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        warn("⚠️ Humanoid not found")
        return
    end
    
    -- Find tool
    local tool = char:FindFirstChildWhichIsA("Tool")
    local fromBackpack = false
    
    if not tool then
        tool = player.Backpack:FindFirstChildWhichIsA("Tool")
        fromBackpack = true
    end
    
    if tool then
        -- Create the clone
        local clone = tool:Clone()
        
        -- Fix all descendants to ensure proper behavior
        for _, descendant in pairs(clone:GetDescendants()) do
            if descendant:IsA("BasePart") then
                descendant.CanCollide = false
                descendant.Massless = true
            elseif descendant:IsA("Motor6D") or descendant:IsA("Motor") then
                -- Preserve motor properties
                descendant.MaxVelocity = descendant.MaxVelocity
            elseif descendant:IsA("Weld") then
                -- Preserve weld properties  
                descendant.C0 = descendant.C0
                descendant.C1 = descendant.C1
            end
        end
        
        -- Put clone in backpack first
        clone.Parent = player.Backpack
        
        -- If the original tool was equipped, we need to refresh it
        if not fromBackpack then
            -- Unequip the tool
            humanoid:UnequipTools()
            
            -- Small wait for the unequip to process
            task.wait(0.1)
            
            -- Re-equip the original tool to reset animations
            humanoid:EquipTool(tool)
            
            -- Wait a bit then also equip the clone to test it
            task.wait(0.2)
            humanoid:UnequipTools()
            task.wait(0.1)
            humanoid:EquipTool(clone)
        end
        
        print("✅ Item duplicated with working animations!")
    else
        warn("⚠️ No tool found to duplicate")
    end
end

